#!/usr/bin/bash

set -e

filename="$(date +%Y-%m-%d_%H.%M.%S).png"
preferred_path="$HOME/nas/safe/pictures/screenshots/$filename"
fallback_path="$HOME/$filename"

# take the screenshot
import -window root "$fallback_path"

actual_path="$fallback_path"
mv "$fallback_path" "$preferred_path" && actual_path="$preferred_path"
echo  "$actual_path" | tee >(clipin)      # put the filename in the clipboard
